# Digital Ocean Spaces Configuration
SPACES_ENDPOINT=sfo3.digitaloceanspaces.com
BUCKET_NAME=ninjacdn
SPACES_KEY=your-spaces-key
SPACES_SECRET_KEY=your-spaces-secret-key

# Server Configuration
PORT=3000
NODE_ENV=production

# Admin Authentication
ADMIN_PASSWORD=your-secure-password
ADMIN2_PASSWORD=your-second-admin-password
SESSION_SECRET=your-session-secret

# ---------------------------------------------------------------
# DO Spaces CORS (configure in DO Console > Spaces > Settings):
#   Allowed Origins: https://your-domain.com, http://localhost:5000
#   Allowed Methods: GET, PUT
#   Allowed Headers: Content-Type
# ---------------------------------------------------------------
